# ============================================================
# EvoCRM — Template de produção
# Copie este arquivo como .env na VPS e preencha os valores
# NÃO comite o .env real
# ============================================================

# --- Banco & Redis ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES
POSTGRES_DATABASE=evo_community

DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_POSTGRES
DB_NAME=evo_community
DB_SSLMODE=disable
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=1h
DB_CONN_MAX_IDLE_TIME=30m

REDIS_URL=redis://:CHANGE_ME_REDIS@redis:6379
REDIS_PASSWORD=CHANGE_ME_REDIS
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_SSL=false
REDIS_KEY_PREFIX=a2a:
REDIS_TTL=3600

POSTGRES_CONNECTION_STRING=postgresql://postgres:CHANGE_ME_POSTGRES@postgres:5432/evo_community

# --- Secrets ---
SECRET_KEY_BASE=CHANGE_ME_SECRET_KEY_BASE
JWT_SECRET_KEY=CHANGE_ME_JWT
JWT_ALGORITHM=HS256
DOORKEEPER_JWT_SECRET_KEY=CHANGE_ME_JWT
DOORKEEPER_JWT_ALGORITHM=hs256
DOORKEEPER_JWT_ISS=evo-auth-service
DOORKEEPER_JWT_AUD=[]
ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION
EVOAI_CRM_API_TOKEN=CHANGE_ME_CRM_TOKEN
BOT_RUNTIME_SECRET=CHANGE_ME_BOT_SECRET
AI_PROCESSOR_API_KEY=CHANGE_ME_PROCESSOR_API_KEY

# --- Modo produção ---
RAILS_ENV=production
RAILS_MAX_THREADS=5
RAILS_LOG_TO_STDOUT=true
LOG_LEVEL=warn
LOG_SIZE=500
VITE_APP_ENV=production
DEBUG=false
SIDEKIQ_CONCURRENCY=10
DISABLE_TELEMETRY=true

# --- URLs públicas ---
FRONTEND_URL=https://crm.SEUDOMINIO.com.br
BACKEND_URL=https://api-crm.SEUDOMINIO.com.br
APP_URL=https://processor-crm.SEUDOMINIO.com.br
API_URL=https://processor-crm.SEUDOMINIO.com.br

# --- URLs internas (container-to-container) ---
EVO_AUTH_SERVICE_URL=http://evo-auth:3001
EVO_AI_CORE_SERVICE_URL=http://evo-core:5555
EVOLUTION_BASE_URL=http://evo-crm:3000
EVO_AUTH_BASE_URL=http://evo-auth:3001
AI_PROCESSOR_URL=http://evo-processor:8000
AI_PROCESSOR_VERSION=v1
EVO_AI_CRM_URL=http://evo-crm:3000
CORE_SERVICE_URL=http://evo-core:5555/api/v1
BOT_RUNTIME_URL=http://evo-bot-runtime:8080
BOT_RUNTIME_POSTBACK_BASE_URL=http://evo-crm:3000

# --- CORS ---
CORS_ORIGINS=https://crm.SEUDOMINIO.com.br,https://api-crm.SEUDOMINIO.com.br

# --- Frontend (build-time, vai embutido no bundle) ---
VITE_API_URL=https://api-crm.SEUDOMINIO.com.br
VITE_AUTH_API_URL=https://auth-crm.SEUDOMINIO.com.br
VITE_WS_URL=https://api-crm.SEUDOMINIO.com.br
VITE_EVOAI_API_URL=https://core-crm.SEUDOMINIO.com.br
VITE_AGENT_PROCESSOR_URL=https://processor-crm.SEUDOMINIO.com.br
VITE_TINYMCE_API_KEY=no-api-key

# --- Processor API ---
API_TITLE=Agent Processor
API_DESCRIPTION=Agent Processor for Evo CRM
API_VERSION=1.0.0
ORGANIZATION_NAME=Sua Empresa
ORGANIZATION_URL=https://SEUDOMINIO.com.br
HOST=0.0.0.0
PORT=8000
TOOLS_CACHE_ENABLED=true
TOOLS_CACHE_TTL=3600
AI_CALL_TIMEOUT_SECONDS=30
LISTEN_ADDR=0.0.0.0:8080

# --- Signup ---
ENABLE_ACCOUNT_SIGNUP=false
ENABLE_PUSH_RELAY_SERVER=true
ENABLE_INBOX_EVENTS=true
MFA_ISSUER=EvoCRM

# --- Email (trocar Mailhog por SMTP real assim que possível) ---
MAILER_SENDER_EMAIL=noreply@SEUDOMINIO.com.br
SMTP_ADDRESS=mailhog
SMTP_PORT=1025
SMTP_DOMAIN=SEUDOMINIO.com.br
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=false
SMTP_USERNAME=
SMTP_PASSWORD=

# --- Storage & outros ---
ACTIVE_STORAGE_SERVICE=local
FB_VERIFY_TOKEN=evolution
FACEBOOK_API_VERSION=v23.0